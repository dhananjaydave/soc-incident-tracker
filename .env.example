# Copy to .env.

# Used to sign session cookies - any long random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
TRACKER_SECRET_KEY=

# The single admin account. Generate the hash with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
TRACKER_ADMIN_USERNAME=admin
TRACKER_ADMIN_PASSWORD_HASH=

# Telegram bot - message @BotFather, /newbot, paste the token here. Use a
# dedicated bot, not one already used by another project (one webhook per
# token).
TRACKER_TELEGRAM_BOT_TOKEN=
# Any random string - generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TRACKER_TELEGRAM_WEBHOOK_SECRET=
# Comma-separated numeric chat ids allowed to use the bot. Message
# @userinfobot to find your own.
TRACKER_ALLOWED_CHAT_IDS=

# How long (hours) a ticket can go without an update before a Telegram
# reminder fires, and how often (minutes) to check.
TRACKER_STALE_HOURS=24
TRACKER_CHECK_INTERVAL_MINUTES=60

# How often (minutes) to check NVD for new CVSS>=7 CVEs and CISA's KEV
# catalog for newly-exploited ones, and how often to check that the
# internal tools below are still reachable.
TRACKER_CVE_CHECK_INTERVAL_MINUTES=240
TRACKER_HEALTH_CHECK_INTERVAL_MINUTES=15

# Daily SOC digest (shift summary + new CVEs + stale tickets) sent via
# Telegram at this UTC hour. Default 2 = 07:30 IST - adjust to your own
# timezone/shift start. Also available on demand via /digest.
TRACKER_DAILY_DIGEST_HOUR_UTC=2

# How long a login session lasts before requiring re-authentication.
# Default 12h covers a full shift without an indefinite/lost-device risk.
TRACKER_SESSION_MAX_AGE_SECONDS=43200

# Internal-only calls to the other SOC Lab tools (Investigate tab) - URLs
# default to their standard deployed ports, only override if different.
# Keys are optional and only checked if the *receiving* service has its
# own key configured.
IOC_ENRICHMENT_API_URL=http://localhost:8001
IOC_ENRICHMENT_API_KEY=
PHISHING_TRIAGE_API_URL=http://localhost:8002
FILE_ANALYSER_API_URL=http://localhost:8004
FILE_ANALYSER_API_KEY=
